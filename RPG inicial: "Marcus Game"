            textbutton "Volver al Mapa" action Jump("volver_al_mapa_desde_tienda") xalign 0.5 text_size 24 text_color "#FF4444" text_hover_color "#FF8888"



label volver_al_mapa_desde_tienda:
    # Simplemente devolvemos al jugador al mapa
    jump game_start


init:
    image mario_idle = "mario_idle1.png"
    image mario_walk_derecha = Animation("mario_walk_right_1.png", 0.2, "mario_walk_right_2.png", 0.2)
    image mario_walk_izquierda = Animation("mario_walk_left_1.png", 0.2, "mario_walk_left_2.png", 0.2)
    image mario_walk_arriba = Animation("mario_walk_down_1.png", 0.2, "mario_walk_down_2.png", 0.2)
    image mario_walk_abajo = Animation("mario_walk_up_1.png", 0.2, "mario_walk_up_2.png", 0.2)
    image mario_walk_salto = Animation("mario_walk_salto_1.png", 0.2, "mario_walk_salto_2.png", 0.2)
    
    image mario_dinamico = ConditionSwitch(
        "mario_estado == 'idle'", "mario_idle", #"mario_saltando", "mario_walk_salto", # Usamos la de arriba como "pose de salto"
        "mario_direccion == 'derecha'", "mario_walk_derecha",
        "mario_direccion == 'izquierda'", "mario_walk_izquierda",
        "mario_direccion == 'arriba'", "mario_walk_arriba",
        "mario_direccion == 'abajo'", "mario_walk_abajo",
        "True", "mario_idle" # Caso por defecto de seguridad
    )


    # --- Imágenes de TOAD ---
    image toad_idle = "toad_idle1.png"
    
    # Nota: Asegúrate de tener estos archivos en la carpeta images
    image toad_walk_derecha = Animation("toad_walk_right_1.png", 0.2, "toad_walk_right_2.png", 0.2)
    image toad_walk_izquierda = Animation("toad_walk_left_1.png", 0.2, "toad_walk_left_2.png", 0.2)
    
    # CORRECCIÓN: "arriba" usa los archivos "up" y "abajo" usa los "down"
    image toad_walk_arriba = Animation("toad_walk_up_1.png", 0.2, "toad_walk_up_2.png", 0.2)
    image toad_walk_abajo = Animation("toad_walk_down_1.png", 0.2, "toad_walk_down_2.png", 0.2)
    


    # Imagen dinámica de Toad (Cambia según estado y dirección)
    image toad_dinamico = ConditionSwitch(
        "store.toad_estado == 'idle'", "toad_idle",
        "store.toad_direccion == 'derecha'", "toad_walk_derecha",
        "store.toad_direccion == 'izquierda'", "toad_walk_izquierda",
        "store.toad_direccion == 'arriba'", "toad_walk_arriba",
        "store.toad_direccion == 'abajo'", "toad_walk_abajo",
        "True", "toad_idle" # Caso por defecto
    )

    # Definimos el movimiento de "rebote"
    transform bloque_golpeado:
        yoffset 0
        linear 0.05 yoffset -10  # Sube rápido
        linear 0.05 yoffset 0    # Baja rápido

    transform camara_subir:
        yalign 1.0 # Comienza abajo (mostrando el suelo/base)
        linear 3.0 yalign 0.0 # Sube lentamente hasta el tope en 3 segundos

