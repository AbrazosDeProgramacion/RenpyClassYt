screen start_screen():
    modal True
    frame:
        xalign 0.5 yalign 0.5
        vbox:
            text "Super Mario Bros" style "title_text"
            textbutton "Jugar" action [Function(reiniciar_juego), Jump("game_start")] style "menu_button"
            textbutton "Salir" action Quit() style "menu_button"

screen game_screen():
    fixed:
        # Fondo Parallax
        #add "bg_level1_parallax" at Transform(xoffset=camera_x_offset * 0.5, yoffset=camera_y_offset * 0.5)

        # Fondo que rellena toda la pantalla sin moverse
        add "images/bg_level1_parallax.png" xysize (1920, 1080)
        
        # Dibujar Mapa
        for r_idx, row in enumerate(nivel_mapa):
            for c_idx, char in enumerate(row):
                $ _display_x = c_idx * TILE_SIZE + camera_x_offset
                $ _display_y = r_idx * TILE_SIZE + camera_y_offset

                if char == 'B': 
                    add "block_tile" xpos _display_x ypos _display_y

                elif char == 'C': 
                    add "coin_tile" xpos _display_x ypos _display_y

                elif char == 'S': # Si la casilla es 'S', dibujamos la tienda
                    add "tienda_img"  xpos _display_x ypos _display_y

      

        # Debug Grid
        if debug_mode:
            for r_idx, row in enumerate(nivel_mapa):
                for c_idx, char in enumerate(row):
                    $ _display_x = c_idx * TILE_SIZE + camera_x_offset
                    $ _display_y = r_idx * TILE_SIZE + camera_y_offset
                    text "[c_idx], [r_idx]" xpos _display_x ypos _display_y size 10 color "#FF0000"


        # Dibujar Toad
        if toad_pos_x != -1 and toad_pos_y != -1:
            $ _toad_x = toad_pos_x * TILE_SIZE + camera_x_offset
            $ _toad_y = toad_pos_y * TILE_SIZE + camera_y_offset
            # CAMBIO AQUÍ:
            add "toad_dinamico" xpos _toad_x ypos _toad_y

        # Dibujar Mario
        $ _mario_x = mario_pos_x * TILE_SIZE + camera_x_offset
        $ _mario_y = mario_pos_y * TILE_SIZE + camera_y_offset
        
        # Comprobamos si lleva el traje especial
        if store.mario_traje_especial:
            add "mario_traje" xpos _mario_x ypos _mario_y
        else:
            add "mario_dinamico" xpos _mario_x ypos _mario_y


        # Interfaz (Puntuación e Inventario)
        frame:
            xalign 0.99 yalign 0.0
            background "#000000AA"
            padding (10, 10)
            vbox:
                text "Puntos: [puntuacion]" color "#fff"
                text "Oro: [oro_actual]" color "#FDFF6C"
                text "Poción Roja: [inventario.get('pocion_roja', 0)]" color "#FF6CA7"
                text "Poción Azul: [inventario.get('pocion_azul', 0)]" color "#B2FFE8"
                
        # Controles
        key "repeat_K_LEFT" action Function(mover_mario, -1, 0)
        key "repeat_K_RIGHT" action Function(mover_mario, 1, 0)
        key "repeat_K_UP" action Function(mover_mario, 0, -1) 
        key "repeat_K_DOWN" action Function(mover_mario, 0, 1)
        key "K_LEFT" action Function(mover_mario, -1, 0)
        key "K_RIGHT" action Function(mover_mario, 1, 0)
        key "K_UP" action Function(mover_mario, 0, -1) 
        key "K_DOWN" action Function(mover_mario, 0, 1)

        # Teclas de Inventario (Ejemplo)
        key "K_z" action Function(usar_item, "pocion_roja")
        key "K_x" action Function(usar_item, "pocion_azul")

        # Timer
        timer 0.05 action Function(game_tick) repeat True


