    # =====================================================
    # 1. MOVIMIENTO Y COLISIONES
    # =====================================================
    def mover_mario(dx, dy):
        if store.game_over: return

        # Actualizar dirección
        if dx > 0: store.mario_direccion = "derecha"
        elif dx < 0: store.mario_direccion = "izquierda"
        elif dy > 0: store.mario_direccion = "abajo" 
        elif dy < 0: store.mario_direccion = "arriba"

        store.mario_estado = "caminando"
        store.mario_ultimo_movimiento = renpy.get_game_runtime()

        # Calcular siguiente posición
        tentative_x = store.mario_pos_x + dx
        tentative_y = store.mario_pos_y + dy

        # Limites del mapa
        if not (0 <= tentative_x < len(store.nivel_mapa[0]) and 0 <= tentative_y < len(store.nivel_mapa)):
            return

        tipo_tile = store.nivel_mapa[tentative_y][tentative_x]

        # Colisión con paredes
        if tipo_tile == 'B':
            return 
            
        # Si no hay pared, nos movemos
        store.mario_pos_x = tentative_x
        store.mario_pos_y = tentative_y

        # ---> NUEVO: Guardar el paso para Toad <---
        if store.toad_siguiendo:
            store.historial_mario.append( (store.mario_pos_x, store.mario_pos_y) )
                # ---> Lógica de Toad siguiendo a Mario <---
        if store.toad_siguiendo and store.toad_pos_x != -1:
            # NUEVO: Toad solo avanza si Mario está a más de 2 pasos de distancia en la lista
            if len(store.historial_mario) > 2:
                store.toad_tick_movimiento += 1
                
                if store.toad_tick_movimiento >= store.toad_velocidad_seguimiento:
                    store.toad_tick_movimiento = 0 
                    siguiente_paso = store.historial_mario.pop(0)
                    store.toad_pos_x = siguiente_paso[0]
                    store.toad_pos_y = siguiente_paso[1]
                    
                    # ---> NUEVO: LÓGICA PARA HABLAR AL CAMINAR <---
                    tiempo_actual = renpy.get_game_runtime()
                    # Solo habla si ha pasado suficiente tiempo desde su última frase
                    if tiempo_actual - store.toad_ultimo_dialogo > store.toad_intervalo_dialogo:
                        import random
                        frase = random.choice(store.dialogos_toad_caminando)
                        store.toad_ultimo_dialogo = tiempo_actual
                        
                        # Mostramos un pequeño cuadro de diálogo en la pantalla
                        renpy.show_screen("dialogo_toad_flotante", frase=frase)

        update_camera_position()
        renpy.restart_interaction()

        # Interacciones
        if tipo_tile == 'S':
            #store.nivel_mapa[tentative_y][tentative_x] = 'S' # con esta opción, la tienda desaparece al salir de ella XD
            renpy.jump("visitar_tienda")
            
        elif tipo_tile == 'T':
            if tentative_x == store.toad_pos_x and tentative_y == store.toad_pos_y:
                store.puntuacion += 100
                store.oro_actual += 100
                store.toad_pos_x = -1 
                store.toad_pos_y = -1
                renpy.jump("hablar_con_toad")


                
        elif tipo_tile == 'C':
            store.puntuacion += 10
            store.nivel_mapa[tentative_y][tentative_x] = 'E' 

        renpy.restart_interaction()

    # =====================================================
    # 2. CÁMARA
    # =====================================================
    def update_camera_position():
        """
        Ajusta la posición de la cámara para seguir a Mario,
        pero se detiene en los bordes del mapa.
        Retorna los offsets x e y de la cámara.
        """
        # Calcular la posición central de Mario en el mundo en píxeles
        mario_world_center_x = store.mario_pos_x * store.TILE_SIZE + store.TILE_SIZE / 2
        mario_world_center_y = store.mario_pos_y * store.TILE_SIZE + store.TILE_SIZE / 2

        # El ancho y alto total del mapa en píxeles
        map_width_pixels = len(store.nivel_mapa[0]) * store.TILE_SIZE
        map_height_pixels = len(store.nivel_mapa) * store.TILE_SIZE

        # Posición ideal de la cámara para centrar a Mario
        ideal_camera_x_offset = int(store.SCREEN_WIDTH / 2 - mario_world_center_x)
        ideal_camera_y_offset = int(store.SCREEN_HEIGHT / 2 - mario_world_center_y)

        # Límites del desplazamiento de la cámara para X
        max_offset_x = 0
        min_offset_x = store.SCREEN_WIDTH - map_width_pixels

        # Límites del desplazamiento de la cámara para Y (similar a X)
        max_offset_y = 0
        min_offset_y = store.SCREEN_HEIGHT - map_height_pixels

        # Limitar el offset de la cámara en X
        store.camera_x_offset = max(min_offset_x, min(max_offset_x, ideal_camera_x_offset))
        # Limitar el offset de la cámara en Y
        store.camera_y_offset = max(min_offset_y, min(max_offset_y, ideal_camera_y_offset))

        # print(f"CAM_UPDATE: Mario en el mundo ({store.mario_pos_x}, {store.mario_pos_y}), Offset Cam: ({store.camera_x_offset}, {store.camera_y_offset})")
        return store.camera_x_offset, store.camera_y_offset # Retorna ambos offsets

    # =====================================================
    # 3. INVENTARIO Y TIENDA
    # =====================================================
    def comprar_item(nombre_item, precio):
        if store.oro_actual >= precio:
            store.oro_actual -= precio
            store.inventario[nombre_item] = store.inventario.get(nombre_item, 0) + 1
            store.mensaje_tienda = f"¡Compraste {nombre_item.replace('_', ' ')}!"
            store.color_mensaje_tienda = "#000"
        else:
            store.mensaje_tienda = "¡Oro insuficiente!"
            store.color_mensaje_tienda = "#000"

    def usar_item(nombre_item):
        if nombre_item in store.inventario and store.inventario[nombre_item] > 0:
            store.inventario[nombre_item] -= 1
            if store.inventario[nombre_item] <= 0:
                del store.inventario[nombre_item]
            
            if nombre_item == "pocion_roja":
                store.vida += 20 # Ahora esta variable existe
                renpy.notify("¡Vida recuperada!")

            if nombre_item == "pocion_azul":
                store.oro_actual += 20 
                renpy.notify(f"¡Tienes {store.oro_actual} piezas de oro!")
        else:
            renpy.notify("¡No tienes ese item!")

    # =====================================================
    # 4. TICK PRINCIPAL
    # =====================================================
    def game_tick():
        if store.game_over: return 

        # Estado Idle
        if store.mario_estado == "caminando" and (renpy.get_game_runtime() - store.mario_ultimo_movimiento > 0.15):
            store.mario_estado = "idle"

        # ---> Lógica del traje de Mario <---
        if store.mario_traje_especial:
            store.mario_traje_duracion -= 1
            if store.mario_traje_duracion <= 0:
                store.mario_traje_especial = False # Se acaba el tiempo, vuelve a la normalidad



        # --- 3. Lógica de Toad ---
        if store.toad_siguiendo and store.toad_pos_x != -1:
            
            # Guardamos la posición ANTES de moverlo para saber hacia dónde va
            vieja_x = store.toad_pos_x
            vieja_y = store.toad_pos_y

            if len(store.historial_mario) > 2:
                store.toad_tick_movimiento += 1
                
                if store.toad_tick_movimiento >= store.toad_velocidad_seguimiento:
                    store.toad_tick_movimiento = 0 
                    
                    # Mover a Toad
                    siguiente_paso = store.historial_mario.pop(0)
                    store.toad_pos_x = siguiente_paso[0]
                    store.toad_pos_y = siguiente_paso[1]
                    
                    # ---> NUEVA LÓGICA DE ANIMACIÓN DE TOAD <---
                    # Si se movió, cambiamos su estado y dirección
                    store.toad_estado = "caminando"
                    
                    # Comparar vieja posición con nueva para saber la dirección
                    if store.toad_pos_x > vieja_x:
                        store.toad_direccion = "derecha"
                    elif store.toad_pos_x < vieja_x:
                        store.toad_direccion = "izquierda"
                    elif store.toad_pos_y > vieja_y:
                        store.toad_direccion = "abajo"
                    elif store.toad_pos_y < vieja_y:
                        store.toad_direccion = "arriba"
                        
                    # Diálogo aleatorio
                    tiempo_actual = renpy.get_game_runtime()
                    if tiempo_actual - store.toad_ultimo_dialogo > store.toad_intervalo_dialogo:
                        import random
                        frase = random.choice(store.dialogos_toad_caminando)
                        store.toad_ultimo_dialogo = tiempo_actual
                        renpy.show_screen("dialogo_toad_flotante", frase=frase)
            
            # Si Toad no se mueve en este tick (porque no hay pasos o espera), ponlo en Idle
            # Nota: Esto es un poco simplificado, funciona si se mueve a saltos
            else:
                # Si el historial está vacío y Mario está lejos, Toad se queda quieto visualmente
                pass 

        update_camera_position()
        renpy.restart_interaction()

        update_camera_position()
        renpy.restart_interaction()

    # =====================================================
    # 5. RESETEO
    # =====================================================
    def reiniciar_juego():
        store.puntuacion = 0
        store.camera_x_offset = 0
        store.camera_y_offset = 0
        store.game_over = False
        store.mario_pos_x = 0
        store.mario_pos_y = 10
        store.toad_pos_x = 25
        store.toad_pos_y = 10
        store.nivel_mapa = [row[:] for row in store.mapas_de_niveles[0]]




