screen dialogo_toad_flotante(frase):
    # Calcular posición de Toad
    $ _toad_x = store.toad_pos_x * store.TILE_SIZE + store.camera_x_offset
    $ _toad_y = store.toad_pos_y * store.TILE_SIZE + store.camera_y_offset

    
    # Burbuja + texto
    fixed:
        frame:
            pos(_toad_x, _toad_y-150)  # depende de la posición del NPC (Toad)
            background "#333333" 

            vbox:
                text "[frase]" align (.5, .5)  text_align 0.5 xmaximum 150 ymaximum 100 
                timer 2.5 action Hide("dialogo_toad_flotante")
        
